{
  "name": "compras-na-25-scraper",
  "version": "1.0.0",
  "description": "Web scraper for Compras na 25",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape": "tsx src/index.ts",
    "scrape:scheduled": "node -e 'setInterval(() => require(\"./dist/index.js\"), 3600000)'"
  },
  "dependencies": {
    "playwright": "latest",
    "@prisma/client": "latest",
    "prisma": "latest",
    "dotenv": "latest"
  },
  "devDependencies": {
    "typescript": "latest",
    "@types/node": "latest",
    "tsx": "latest"
  }
}
